{
  "name": "vibe-app-tauri",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn desktop:dev",
    "build": "yarn desktop:build",
    "desktop:dev": "vite --host 127.0.0.1 --port 1420 --mode desktop-development",
    "desktop:build": "tsc --noEmit && vite build --mode desktop-production",
    "desktop:smoke": "tauri build --debug --no-bundle",
    "tauri:build:preview": "tauri build --config src-tauri/tauri.preview.conf.json",
    "tauri:build:production-candidate": "tauri build --config src-tauri/tauri.production-candidate.conf.json",
    "mobile:android:prepare": "node ./scripts/prepare-android-project.mjs",
    "mobile:android:init": "tauri android init --ci && yarn mobile:android:prepare",
    "mobile:android:dev-server": "vite --host 0.0.0.0 --port 1420 --mode mobile-development",
    "mobile:android:frontend": "tsc --noEmit && vite build --mode mobile-production",
    "mobile:android:preview:apk": "yarn mobile:android:prepare && tauri android build --debug --apk -t aarch64",
    "mobile:android:production-candidate:apk": "yarn mobile:android:prepare && tauri android build --apk -t aarch64",
    "mobile:android:dev": "yarn mobile:android:prepare && tauri android dev",
    "mobile:android:smoke": "yarn mobile:android:prepare && tauri android build --debug --apk -t aarch64",
    "mobile:android:build": "yarn mobile:android:prepare && tauri android build --debug --apk",
    "mobile:android:run": "yarn mobile:android:prepare && tauri android run",
    "browser:dev": "vite --host 127.0.0.1 --port 1420 --mode browser-development",
    "browser:build": "tsc --noEmit && vite build --mode browser-production",
    "browser:build:preview": "tsc --noEmit && vite build --mode browser-preview",
    "browser:smoke": "yarn browser:build",
    "release": "node ./release.cjs",
    "release:prepare:preview": "node ./scripts/write-release-tauri-properties.mjs preview",
    "release:prepare:production-candidate": "node ./scripts/write-release-tauri-properties.mjs production-candidate",
    "release:package:preview": "node ./scripts/package-release-artifacts.mjs preview",
    "release:package:production-candidate": "node ./scripts/package-release-artifacts.mjs production-candidate",
    "release:build:preview": "sh ./release-dev.sh",
    "release:build:production-candidate": "sh ./release-production.sh",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:bootstrap": "vitest run sources/shared/bootstrap-config.test.ts src/bootstrap-runtime.test.ts",
    "validate:promotion": "yarn typecheck && yarn test && yarn tauri:test && yarn desktop:build && yarn browser:smoke && yarn mobile:android:smoke && yarn --cwd ../../scripts metrics:vibe-app-tauri && yarn --cwd ../../scripts validate:vibe-app-tauri-promotion && yarn desktop:smoke",
    "tauri:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "tauri:dev": "tauri dev",
    "tauri:smoke": "yarn desktop:smoke",
    "tauri:build": "tauri build",
    "release:bundle": "yarn tauri:build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "diff": "^8.0.2",
    "i18next": "^24.0.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "libsodium-wrappers": "0.8.2",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^15.0.0",
    "react-syntax-highlighter": "^15.6.1",
    "socket.io-client": "^4.8.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/qrcode": "^1.5.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "react-test-renderer": "19.2.0",
    "typescript": "5.9.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}
