{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vibe",
  "version": "0.1.0",
  "identifier": "engineering.vibe.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "yarn start:dev",
    "beforeBuildCommand": "yarn expo export --platform web --output-dir dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vibe",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
