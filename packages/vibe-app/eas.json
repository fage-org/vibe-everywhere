{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "VIBE_APP_ENV": "development",
        "APP_ENV": "development",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "development-store": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "store",
      "channel": "development",
      "env": {
        "VIBE_APP_ENV": "development",
        "APP_ENV": "development",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "VIBE_APP_ENV": "preview",
        "APP_ENV": "preview",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "preview-store": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "VIBE_APP_ENV": "preview",
        "APP_ENV": "preview",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "VIBE_APP_ENV": "production",
        "APP_ENV": "production",
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    }
  }
}
