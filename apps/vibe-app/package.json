{
  "name": "vibe-app",
  "private": true,
  "version": "0.1.13",
  "packageManager": "npm@11.12.0",
  "type": "module",
  "engines": {
    "node": ">=24.14.0 <25",
    "npm": ">=11.12.0 <12"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 1420",
    "tauri": "tauri",
    "android:init": "tauri android init --ci --skip-targets-install",
    "android:doctor": "bash ../../scripts/android-doctor.sh",
    "android:build:debug:apk": "tauri android build --debug --apk --target aarch64 --ci",
    "android:build:apk": "tauri android build --apk --target aarch64 --ci",
    "android:build:aab": "tauri android build --aab --target aarch64 --ci"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.31",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  }
}
