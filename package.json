{
  "name": "vibe-remote",
  "private": true,
  "scripts": {
    "postinstall": "node ./scripts/postinstall.cjs",
    "app-logs": "cargo run -p vibe-app-logs --",
    "app": "yarn workspace vibe-app-tauri tauri:dev",
    "app:validate": "yarn workspace vibe-app-tauri validate:promotion",
    "app:release:validate": "yarn --cwd scripts validate:vibe-app-tauri-release",
    "app:metrics": "yarn --cwd scripts metrics:vibe-app-tauri",
    "app:promotion-ready": "yarn --cwd scripts validate:vibe-app-tauri-promotion --promotion-ready"
  },
  "workspaces": {
    "packages": [
      "packages/vibe-app-tauri"
    ],
    "nohoist": [
      "**/zod",
      "**/react",
      "**/react-dom",
      "**/react-native",
      "**/react-native/**",
      "**/react-native-edge-to-edge/**",
      "**/react-native-incall-manager/**"
    ]
  },
  "packageManager": "yarn@1.22.22"
}
